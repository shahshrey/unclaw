# Agent configuration — sourced by start-agent.sh and scripts.
# All vars are auto-exported (set -a) so MCP servers and child processes inherit them.
# Edit these values after running /setup, or set them manually.

AGENT_SESSION_NAME="agent"
AGENT_CHANNEL=""
# AGENT_CHANNEL="plugin:telegram@claude-plugins-official"

# Per-agent Telegram isolation. Each agent gets its own bot token + access list.
# The Telegram MCP plugin reads this env var; without it all agents share ~/.claude/channels/telegram/.
# TELEGRAM_STATE_DIR="$HOME/.claude/channels/telegram-<agent-name>"
