<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.{{AGENT_SESSION_NAME}}.task.distill-session</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>{{PROJECT_DIR}}/.claude/scripts/run-agent-command.sh</string>
		<string>/distill-session</string>
	</array>
	<key>EnvironmentVariables</key>
	<dict>
		<key>AGENT_SESSION_NAME</key>
		<string>{{AGENT_SESSION_NAME}}</string>
	</dict>
	<key>StartInterval</key>
	<integer>21600</integer>
	<key>StandardOutPath</key>
	<string>{{PROJECT_DIR}}/.claude/runtime/launchd/distill-out.log</string>
	<key>StandardErrorPath</key>
	<string>{{PROJECT_DIR}}/.claude/runtime/launchd/distill-err.log</string>
</dict>
</plist>
